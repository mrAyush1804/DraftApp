<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".MainActivity">

    <!-- AppBar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/white"
            app:contentInsetStart="16dp"
            app:contentInsetEnd="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Hamburger Menu Icon -->
                <ImageView
                    android:id="@+id/ivMenu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="4dp"
                    android:src="@drawable/menuhome"
                    app:tint="#1565C0" />

                <!-- Toolbar Title -->
                <TextView
                    android:id="@+id/tvToolbarTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Drafts"
                    android:textColor="#1A1A2E"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold" />

                <!-- Three-dot overflow menu -->
                <ImageView
                    android:id="@+id/ivOverflow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="4dp"
                    android:src="@drawable/menuhome"

                    app:tint="#1A1A2E" />

            </LinearLayout>
        </androidx.appcompat.widget.Toolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="16dp">

            <!-- Header: Digital Atelier -->
            <TextView
                android:id="@+id/tvHeaderTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Digital Atelier"
                android:textColor="#1A1A2E"
                android:textSize="30sp"
                android:fontFamily="serif"
                android:textStyle="bold"
                android:letterSpacing="0.01"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvHeaderSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CURRENT PROJECTS &amp; ARCHIVES"
                android:textColor="#9E9E9E"
                android:textSize="11sp"
                android:fontFamily="sans-serif"
                android:letterSpacing="0.10"
                android:layout_marginBottom="24dp" />

            <!-- ────────────────────────────────────────────────────────── -->
            <!--  Draft Item 1 — EDITABLE                                  -->
            <!-- ────────────────────────────────────────────────────────── -->
            <include layout="@layout/item_draft"
                android:id="@+id/itemDraft1" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0"
                android:layout_marginVertical="4dp" />

            <!-- Draft Item 2 — EDITABLE -->
            <include layout="@layout/item_draft"
                android:id="@+id/itemDraft2" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0"
                android:layout_marginVertical="4dp" />

            <!-- Draft Item 3 — LOCKED -->
            <include layout="@layout/item_draft"
                android:id="@+id/itemDraft3" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0"
                android:layout_marginVertical="4dp" />

            <!-- Draft Item 4 — EDITABLE -->
            <include layout="@layout/item_draft"
                android:id="@+id/itemDraft4" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0"
                android:layout_marginVertical="4dp" />

            <!-- Draft Item 5 — LOCKED -->
            <include layout="@layout/item_draft"
                android:id="@+id/itemDraft5" />

            <!-- ────────────────────────────────────────────────────────── -->
            <!--  Draft of the Day Highlight Card                          -->
            <!-- ────────────────────────────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardHighlight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#1565C0">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- HIGHLIGHT label -->
                    <TextView
                        android:id="@+id/tvHighlightLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HIGHLIGHT"
                        android:textColor="#BBDEFB"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.15"
                        android:layout_marginBottom="8dp" />

                    <!-- Draft of the Day Title -->
                    <TextView
                        android:id="@+id/tvDraftOfDayTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Draft of the Day"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:fontFamily="serif"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <!-- Description -->
                    <TextView
                        android:id="@+id/tvDraftOfDayDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Complete the 'Vertical Garden' schematic for the City Council meeting."
                        android:textColor="#E3F2FD"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif"
                        android:lineSpacingExtra="3dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- FAB — New Draft -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabNewDraft"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="72dp"
        android:text="+ New Draft"
        android:textColor="@color/white"
        android:textSize="14sp"
        app:backgroundTint="#1A1A2E"
        app:elevation="6dp"
        app:icon="@null" />

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/white"
        app:elevation="8dp"
        app:itemTextColor="#1565C0"
        app:itemIconTint="#1565C0"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/buttomnavmenu" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>